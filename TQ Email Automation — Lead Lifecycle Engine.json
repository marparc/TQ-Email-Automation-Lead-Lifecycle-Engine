    {
      "parameters": {
        "jsCode": "// Pull lead from the last node that had it, not from Notion's response\nconst lead   = $('Normalise Lead Payload').first().json;\nconst C      = lead.CONFIG;\nconst pageId = $('CRM - Create Lead Record (Notion)').first().json.id;\n\nconst subject = `We got your request, ${lead.firstName}`;\n\nconst html = `\n<p>Hi ${lead.firstName},</p>\n<p>Thanks for reaching out to <strong>${C.brand}</strong>. ${C.offerOneLiner}</p>\n<p>Quickest next step — grab a time that works for you:<br>\n<a href=\"${C.calendarLink}\">Book your ${C.meetingLabel} →</a></p>\n<p>If the timing isn't right, just reply to this email and let me know.</p>\n<p>${C.fromName}</p>\n`;\n\nreturn [{ json: {\n  to:      lead.email,\n  from:    `${C.fromName} <${C.fromEmail}>`,\n  replyTo: C.replyTo,\n  subject,\n  html,\n  leadPageId: pageId,\n  lead,\n  CONFIG:  C\n}}];"
      },
