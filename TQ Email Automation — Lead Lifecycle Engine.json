      "parameters": {
        "jsCode": "const body   = $('Lead Intake Webhook').first().json.body || $('Lead Intake Webhook').first().json;\nconst config = $('BRAND CONFIG (edit here only)').first().json.CONFIG;\n\nconst lead = {\n  firstName:   body.firstName || body.first_name || body.name?.split(' ')[0] || 'there',\n  lastName:    body.lastName  || body.last_name  || body.name?.split(' ').slice(1).join(' ') || '',\n  email:       (body.email || '').toLowerCase().trim(),\n  phone:       body.phone || body.phone_number || '',\n  source:      body.source || body.utm_source || 'form',\n  createdAt:   new Date().toISOString(),\n  stage:       'New',\n  booked:      false,\n  CONFIG:      config\n};\n\nif (!lead.email) throw new Error('Lead payload missing email — check form field mapping.');\n\nreturn [{ json: lead }];"
      },
